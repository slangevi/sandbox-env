        exit 1
    fi

    # Require a model name
    if [ $# -eq 0 ]; then
        error "Usage: sandbox remote-local <model> [--name <session>] [--spawn <mode>]"
        error "Example: sandbox remote-local qwen3.5"
        exit 1
    fi
    local model="$1"
    shift
    validate_model "$model"

    # Check ollama feature
    local has_ollama=false
    while IFS= read -r feature; do
