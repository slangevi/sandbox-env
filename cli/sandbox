#!/bin/bash
set -euo pipefail

# Resolve the sandbox-env repo root (where this script lives)
SANDBOX_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log()   { echo -e "${GREEN}[sandbox]${NC} $*"; }
warn()  { echo -e "${YELLOW}[sandbox]${NC} $*"; }
error() { echo -e "${RED}[sandbox]${NC} $*" >&2; }

# Check for required tools
require_tool() {
    if ! command -v "$1" &>/dev/null; then
        error "Required tool '$1' not found. Please install it."
        exit 1
    fi
}

require_tool docker
require_tool yq

# ── YAML config helpers ──────────────────────────────────────────────

CONFIG_FILE=""

find_config() {
    if [ -f "${1:-sandbox.yaml}" ]; then
        CONFIG_FILE="${1:-sandbox.yaml}"
    elif [ -f "sandbox.yml" ]; then
        CONFIG_FILE="sandbox.yml"
    else
        error "No sandbox.yaml found in current directory."
        exit 1
    fi
}

config_get() {
    local val
    val=$(yq -r "$1" "$CONFIG_FILE" 2>/dev/null) || true
    if [ "$val" = "null" ] || [ -z "$val" ]; then
        return 0
    fi
    echo "$val"
}

config_get_default() {
    local query="$1"
    local default="$2"
    local val
    val=$(config_get "$query")
    echo "${val:-$default}"
}

project_name() {
    config_get '.name'
}

# ── Input validation ────────────────────────────────────────────────

validate_name() {
    local name="$1"
    if [[ ! "$name" =~ ^[a-z0-9][a-z0-9._-]*$ ]]; then
        error "Invalid project name '$name'. Must match: ^[a-z0-9][a-z0-9._-]*$"
        exit 1
    fi
}

validate_feature() {
    local feature="$1"
    if [[ ! "$feature" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
        error "Invalid feature name '$feature'. Must match: ^[a-z0-9][a-z0-9-]*$"
        exit 1
    fi
}

validate_package() {
    local pkg="$1"
    if [[ ! "$pkg" =~ ^[a-z0-9][a-z0-9.+_-]*$ ]]; then
        error "Invalid package name '$pkg'. Must match: ^[a-z0-9][a-z0-9.+_-]*$"
        exit 1
    fi
}

# ── Commands ─────────────────────────────────────────────────────────

cmd_build_base() {
    log "Building base image..."
    docker build \
        -f "$SANDBOX_ROOT/base/Dockerfile" \
        -t sandbox-base:latest \
        "$SANDBOX_ROOT"
    log "Base image built: sandbox-base:latest"
}

cmd_build() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi
    validate_name "$name"

    log "Building project image: sandbox-${name}:latest"

    # Generate Dockerfile from template
    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf $tmpdir" EXIT

    local dockerfile="$tmpdir/Dockerfile"
    local features_block=""
    local packages_block=""
    local setup_block=""

    # Features
    while IFS= read -r feature; do
        [ -z "$feature" ] && continue
        validate_feature "$feature"
        local script="$SANDBOX_ROOT/features/${feature}.sh"
        if [ ! -f "$script" ]; then
            error "Feature script not found: $script"
            exit 1
        fi
        cp "$script" "$tmpdir/${feature}.sh"
        features_block="${features_block}COPY ${feature}.sh /tmp/${feature}.sh
RUN chmod +x /tmp/${feature}.sh && /tmp/${feature}.sh && rm /tmp/${feature}.sh
"
    done < <(config_get '.features[]')

    # Packages
    local packages=""
    while IFS= read -r pkg; do
        [ -z "$pkg" ] && continue
        validate_package "$pkg"
        packages="${packages} ${pkg}"
    done < <(config_get '.packages[]')
    if [ -n "$packages" ]; then
        packages_block="RUN apt-get update && apt-get install -y --no-install-recommends${packages} && rm -rf /var/lib/apt/lists/*"
    fi

    # Custom setup script
    local setup_path
    setup_path=$(config_get '.setup')
    if [ -n "$setup_path" ]; then
        if [ ! -f "$setup_path" ]; then
            error "Setup script not found: $setup_path"
            exit 1
        fi
        cp "$setup_path" "$tmpdir/custom-setup.sh"
        setup_block="COPY custom-setup.sh /tmp/custom-setup.sh
RUN chmod +x /tmp/custom-setup.sh && /tmp/custom-setup.sh && rm /tmp/custom-setup.sh"
    fi

    # Generate Dockerfile by reading template and replacing placeholders
    # (Using line-by-line replacement to avoid awk/sed issues with & in strings)
    while IFS= read -r line; do
        case "$line" in
            *%%FEATURES%%*) printf '%s\n' "$features_block" ;;
            *%%PACKAGES%%*) printf '%s\n' "$packages_block" ;;
            *%%SETUP%%*)    printf '%s\n' "$setup_block" ;;
            *)              printf '%s\n' "$line" ;;
        esac
    done < "$SANDBOX_ROOT/templates/Dockerfile.project.tmpl" > "$dockerfile"

    # Build
    docker build \
        -f "$dockerfile" \
        -t "sandbox-${name}:latest" \
        "$tmpdir"

    log "Project image built: sandbox-${name}:latest"
}

cmd_run() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi

    # Check image exists
    if ! docker image inspect "sandbox-${name}:latest" &>/dev/null; then
        error "Project image not found. Run 'sandbox build' first."
        exit 1
    fi

    # Parse --headless flag
    local mode
    mode=$(config_get_default '.claude.mode' 'interactive')
    local passthrough_args=()
    local parsing_passthrough=false

    shift # remove 'run' from args
    while [ $# -gt 0 ]; do
        if [ "$1" = "--" ]; then
            parsing_passthrough=true
            shift
            continue
        fi
        if $parsing_passthrough; then
            passthrough_args+=("$1")
        elif [ "$1" = "--headless" ]; then
            mode="headless"
        fi
        shift
    done

    # Build docker run args
    local docker_args=(
        "--name" "sandbox-${name}"
        "--rm"
        "--hostname" "sandbox"
        "--security-opt" "no-new-privileges"
        "--pids-limit" "256"
    )

    # ── Persistent volumes ──────────────────────────────────────────
    # Per-project: auth, home dotfiles, package caches
    docker_args+=("-v" "sandbox-${name}-claude:/home/node/.claude")
    docker_args+=("-v" "sandbox-${name}-home:/home/node/.persistent")
    docker_args+=("-v" "sandbox-${name}-cache:/home/node/.cache")

    # Shared: Ollama models (only if ollama feature is in config)
    local has_ollama=false
    while IFS= read -r feature; do
        [ "$feature" = "ollama" ] && has_ollama=true
    done < <(config_get '.features[]')
    if $has_ollama; then
        docker_args+=("-v" "sandbox-ollama-models:/home/node/.ollama")
    fi

    # Mounts from config
    local has_mounts=false
    local mount_count
    mount_count=$(yq '.mounts | length' "$CONFIG_FILE" 2>/dev/null || echo "0")
    if [ "$mount_count" != "null" ] && [ "$mount_count" -gt 0 ] 2>/dev/null; then
        for i in $(seq 0 $((mount_count - 1))); do
            has_mounts=true
            local host_path container_path readonly_flag
            host_path=$(yq -r ".mounts[$i].host" "$CONFIG_FILE")
            container_path=$(yq -r ".mounts[$i].container" "$CONFIG_FILE")
            readonly_flag=$(yq -r ".mounts[$i].readonly // false" "$CONFIG_FILE")

            # Expand ~ in host path
            host_path="${host_path/#\~/$HOME}"
            # Resolve relative paths (relative to config file location)
            if [[ "$host_path" == .* ]]; then
                host_path="$(cd "$(dirname "$CONFIG_FILE")" && pwd)/$(echo "$host_path" | sed 's|^\./||')"
            fi

            local mount_spec="${host_path}:${container_path}"
            if [ "$readonly_flag" = "true" ]; then
                mount_spec="${mount_spec}:ro"
            fi
            docker_args+=("-v" "$mount_spec")
        done
    fi

    # Default mount if none specified
    if ! $has_mounts; then
        docker_args+=("-v" "$(pwd):/workspace")
    fi

    # Environment variables from config
    local env_keys
    env_keys=$(yq -r '.env // {} | keys | .[]' "$CONFIG_FILE" 2>/dev/null) || true
    while IFS= read -r key; do
        [ -z "$key" ] && continue
        # Block dangerous env var overrides
        case "$key" in
            PATH|LD_PRELOAD|LD_LIBRARY_PATH|SANDBOX_FIREWALL|SANDBOX_ALLOWED_DOMAINS)
                warn "Skipping dangerous env var '$key' — these cannot be set via sandbox.yaml"
                continue
                ;;
        esac
        local val
        val=$(yq -r ".env.${key}" "$CONFIG_FILE")
        docker_args+=("-e" "${key}=${val}")
    done <<< "$env_keys"

    # Git config from sandbox.yaml (passed as SANDBOX_GIT_* env vars)
    # e.g. git.user.name -> SANDBOX_GIT_USER__NAME
    local git_keys
    git_keys=$(yq -r '.git // {} | keys | .[]' "$CONFIG_FILE" 2>/dev/null) || true
    while IFS= read -r key; do
        [ -z "$key" ] && continue
        local val
        val=$(yq -r ".git.\"${key}\"" "$CONFIG_FILE")
        # Convert key: user.name -> USER__NAME
        local env_key
        env_key=$(echo "$key" | tr '[:lower:]' '[:upper:]' | sed 's/\./__/g')
        docker_args+=("-e" "SANDBOX_GIT_${env_key}=${val}")
    done <<< "$git_keys"

    # Firewall mode
    local firewall
    firewall=$(config_get_default '.firewall' 'open')
    docker_args+=("-e" "SANDBOX_FIREWALL=${firewall}")

    if [ "$firewall" = "strict" ]; then
        docker_args+=("--cap-add" "NET_ADMIN" "--cap-add" "NET_RAW")

        # Pass allowed_domains as comma-separated env var
        local domains=""
        local domain_count
        domain_count=$(yq '.allowed_domains | length' "$CONFIG_FILE" 2>/dev/null || echo "0")
        if [ "$domain_count" != "null" ] && [ "$domain_count" -gt 0 ] 2>/dev/null; then
            for i in $(seq 0 $((domain_count - 1))); do
                local domain
                domain=$(yq -r ".allowed_domains[$i]" "$CONFIG_FILE")
                domains="${domains:+${domains},}${domain}"
            done
        fi
        if [ -n "$domains" ]; then
            docker_args+=("-e" "SANDBOX_ALLOWED_DOMAINS=${domains}")
        fi
    fi

    # Claude Code permissions
    local skip_permissions
    skip_permissions=$(config_get_default '.claude.skip_permissions' 'false')
    if [ "$skip_permissions" = "true" ]; then
        if [ "$firewall" != "strict" ]; then
            warn "WARNING: skip_permissions is enabled without strict firewall!"
            warn "This is dangerous — Claude can access any network resource."
            warn "Set 'firewall: strict' in sandbox.yaml for safety."
        fi
    fi

    local skip_permissions_flag=""
    if [ "$skip_permissions" = "true" ]; then
        skip_permissions_flag="--dangerously-skip-permissions"
    fi

    # Resource limits
    local memory_limit
    memory_limit=$(config_get '.resources.memory')
    if [ -n "$memory_limit" ]; then
        docker_args+=("--memory" "$memory_limit")
    fi

    local cpu_limit
    cpu_limit=$(config_get '.resources.cpus')
    if [ -n "$cpu_limit" ]; then
        docker_args+=("--cpus" "$cpu_limit")
    fi

    # Run
    if [ "$mode" = "headless" ]; then
        if [ ${#passthrough_args[@]} -eq 0 ]; then
            error "Headless mode requires a prompt. Usage: sandbox run --headless -- \"your prompt here\""
            exit 1
        fi
        # Capture headless output to log file
        local log_dir="${HOME}/.sandbox/logs/${name}"
        mkdir -p "$log_dir"
        local log_file="${log_dir}/$(date +%Y%m%d-%H%M%S).log"
        log "Running sandbox-${name} in headless mode..."
        log "Output will be saved to: $log_file"

        local timeout_val
        timeout_val=$(config_get '.claude.timeout')
        local timeout_cmd=""
        if [ -n "$timeout_val" ]; then
            timeout_cmd="timeout $timeout_val"
        fi

        $timeout_cmd docker run "${docker_args[@]}" \
            "sandbox-${name}:latest" \
            claude ${skip_permissions_flag} -p "${passthrough_args[*]}" 2>&1 | tee "$log_file"
    elif [ ${#passthrough_args[@]} -gt 0 ]; then
        log "Running sandbox-${name} with command..."
        docker run "${docker_args[@]}" \
            "sandbox-${name}:latest" \
            "${passthrough_args[@]}"
    else
        log "Running sandbox-${name} interactively..."
        docker run -it "${docker_args[@]}" \
            "sandbox-${name}:latest"
    fi
}

cmd_shell() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi
    log "Opening shell in sandbox-${name}..."
    docker exec -it "sandbox-${name}" /bin/zsh
}

cmd_stop() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi
    log "Stopping sandbox-${name}..."
    docker stop "sandbox-${name}" 2>/dev/null || true
    log "Stopped."
}

cmd_clean() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi
    log "Removing image sandbox-${name}:latest..."
    docker rmi "sandbox-${name}:latest" 2>/dev/null || true

    # Remove per-project volumes
    for suffix in claude home cache; do
        local vol="sandbox-${name}-${suffix}"
        if docker volume inspect "$vol" &>/dev/null; then
            docker volume rm "$vol" 2>/dev/null || true
            log "Removed volume: ${vol}"
        fi
    done

    log "Cleaned."
}

cmd_clean_models() {
    local vol="sandbox-ollama-models"
    if docker volume inspect "$vol" &>/dev/null; then
        docker volume rm "$vol" 2>/dev/null || true
        log "Removed shared Ollama models volume: ${vol}"
    else
        log "No Ollama models volume found."
    fi
}

cmd_login() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi

    # Check image exists
    if ! docker image inspect "sandbox-${name}:latest" &>/dev/null; then
        error "Project image not found. Run 'sandbox build' first."
        exit 1
    fi

    local claude_volume="sandbox-${name}-claude"
    log "Authenticating Claude Code for sandbox-${name}..."
    log "Config stored in Docker volume: ${claude_volume}"
    echo ""

    docker run -it --rm \
        --hostname sandbox \
        -v "${claude_volume}:/home/node/.claude" \
        "sandbox-${name}:latest" \
        claude login
}

cmd_logs() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi

    local log_dir="${HOME}/.sandbox/logs/${name}"
    if [ ! -d "$log_dir" ]; then
        error "No logs found for sandbox-${name}."
        exit 1
    fi

    # Find the most recent log file
    local latest
    latest=$(ls -t "$log_dir"/*.log 2>/dev/null | head -1)
    if [ -z "$latest" ]; then
        error "No log files found in $log_dir"
        exit 1
    fi

    log "Showing: $latest"
    cat "$latest"
}

cmd_status() {
    log "Sandbox containers:"
    echo ""
    local found=false
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        found=true
        local container_name status image
        container_name=$(echo "$line" | awk '{print $1}')
        image=$(echo "$line" | awk '{print $2}')
        status=$(echo "$line" | cut -d' ' -f3-)
        printf "  %-30s %-35s %s\n" "$container_name" "$image" "$status"
    done < <(docker ps --filter "name=sandbox-" --format "{{.Names}} {{.Image}} {{.Status}}" 2>/dev/null)

    if ! $found; then
        echo "  No sandbox containers running."
    fi
    echo ""
}

cmd_exec() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi

    if ! docker container inspect "sandbox-${name}" &>/dev/null; then
        error "No running sandbox found. Run 'sandbox run' first."
        exit 1
    fi

    shift # remove 'exec' from args
    if [ $# -eq 0 ]; then
        error "Usage: sandbox exec <command> [args...]"
        exit 1
    fi

    docker exec -it "sandbox-${name}" "$@"
}

cmd_models() {
    local subcmd="${2:-}"
    shift 2 2>/dev/null || true

    # Use the official ollama image with the shared models volume
    local ollama_image="ollama/ollama:latest"
    local ollama_volume="sandbox-ollama-models"

    _ollama_run() {
        # Start Ollama server in a temporary container, wait for ready, run command
        local container_name="sandbox-ollama-tmp-$$"
        docker run -d --rm --name "$container_name" \
            -v "${ollama_volume}:/root/.ollama" \
            "$ollama_image" serve >/dev/null

        # Wait for Ollama to be ready
        for i in $(seq 1 15); do
            if docker exec "$container_name" ollama list &>/dev/null; then
                break
            fi
            sleep 1
        done

        # Run the command
        docker exec "$container_name" "$@"
        local exit_code=$?

        # Clean up
        docker stop "$container_name" >/dev/null 2>&1 || true
        return $exit_code
    }

    case "$subcmd" in
        pull)
            if [ $# -eq 0 ]; then
                error "Usage: sandbox models pull <model> [model...]"
                exit 1
            fi
            if ! docker volume inspect "$ollama_volume" &>/dev/null; then
                docker volume create "$ollama_volume" >/dev/null
            fi
            for model in "$@"; do
                log "Pulling model: $model"
                _ollama_run ollama pull "$model"
            done
            ;;
        list)
            if ! docker volume inspect "$ollama_volume" &>/dev/null; then
                log "No models downloaded yet. Use: sandbox models pull <model>"
                return 0
            fi
            _ollama_run ollama list
            ;;
        rm)
            if [ $# -eq 0 ]; then
                error "Usage: sandbox models rm <model> [model...]"
                exit 1
            fi
            if ! docker volume inspect "$ollama_volume" &>/dev/null; then
                error "No Ollama models volume found."
                exit 1
            fi
            for model in "$@"; do
                log "Removing model: $model"
                _ollama_run ollama rm "$model"
            done
            ;;
        *)
            cat <<'USAGE'
Usage: sandbox models <command> [args]

Commands:
  pull <model>    Download an Ollama model (e.g. llama3.2, codellama)
  list            Show downloaded models
  rm <model>      Remove a downloaded model

Models are stored in a shared volume (sandbox-ollama-models) and
available to all projects with the ollama feature.
USAGE
            ;;
    esac
}

cmd_init() {
    if [ -f sandbox.yaml ] || [ -f sandbox.yml ]; then
        error "sandbox.yaml already exists in this directory."
        exit 1
    fi

    local name
    name=$(basename "$(pwd)")
    # Sanitize to lowercase alphanumeric with hyphens
    name=$(echo "$name" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]/-/g' | sed 's/^[^a-z0-9]/x/')

    cat > sandbox.yaml <<YAML
name: ${name}

features: []
  # - python
  # - node-extra
  # - rust
  # - go
  # - aws
  # - gcloud
  # - ollama
  # - llm

packages: []
  # - ripgrep
  # - tree

env: {}

# git:
#   user.name: Your Name
#   user.email: you@example.com

mounts:
  - host: .
    container: /workspace

firewall: open
# allowed_domains:
#   - api.example.com

# setup: ./scripts/custom-setup.sh

claude:
  mode: interactive
  args: []
# claude:
#   mode: interactive
#   skip_permissions: false   # auto-adds --dangerously-skip-permissions
#   timeout: 30m              # headless mode timeout
#   args: []

# resources:
#   memory: 4g
#   cpus: 2
YAML

    log "Created sandbox.yaml for '${name}'"
    log "Edit it to add features and packages, then run: sandbox build"
}

cmd_help() {
    cat <<'USAGE'
Usage: sandbox <command> [options]

Commands:
  build-base          Build the base sandbox image
  build               Build project image from sandbox.yaml
  run [--headless]    Run the sandbox container
  login               Authenticate Claude Code for this project
  exec <cmd>          Run a command in the running sandbox
  shell               Open a shell in the running sandbox
  stop                Stop the running sandbox
  status              Show running sandbox containers
  logs                Show output from the last headless run
  models <cmd>        Manage Ollama models (pull, list, rm)
  clean               Remove project image and all project volumes
  clean-models        Remove shared Ollama models volume
  init                Generate a starter sandbox.yaml

Options:
  -h, --help          Show this help message
USAGE
}

# ── Main ─────────────────────────────────────────────────────────────

case "${1:-help}" in
    build-base)     cmd_build_base ;;
    build)          cmd_build ;;
    run)            cmd_run "$@" ;;
    login)          cmd_login ;;
    exec)           cmd_exec "$@" ;;
    shell)          cmd_shell ;;
    stop)           cmd_stop ;;
    status)         cmd_status ;;
    logs)           cmd_logs ;;
    models)         cmd_models "$@" ;;
    clean)          cmd_clean ;;
    clean-models)   cmd_clean_models ;;
    init)           cmd_init ;;
    help|-h|--help) cmd_help ;;
    *)
        error "Unknown command: $1"
        cmd_help
        exit 1
        ;;
esac
