#!/bin/bash
set -euo pipefail

# Resolve the sandbox-env repo root (where this script lives)
SANDBOX_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log()   { echo -e "${GREEN}[sandbox]${NC} $*"; }
warn()  { echo -e "${YELLOW}[sandbox]${NC} $*"; }
error() { echo -e "${RED}[sandbox]${NC} $*" >&2; }

# Check for required tools
require_tool() {
    if ! command -v "$1" &>/dev/null; then
        error "Required tool '$1' not found. Please install it."
        exit 1
    fi
}

require_tool docker
require_tool yq

# ── YAML config helpers ──────────────────────────────────────────────

CONFIG_FILE=""

find_config() {
    if [ -f "${1:-sandbox.yaml}" ]; then
        CONFIG_FILE="${1:-sandbox.yaml}"
    elif [ -f "sandbox.yml" ]; then
        CONFIG_FILE="sandbox.yml"
    else
        error "No sandbox.yaml found in current directory."
        exit 1
    fi

    # Validate YAML is parseable
    if ! yq '.' "$CONFIG_FILE" >/dev/null 2>&1; then
        error "Invalid YAML in $CONFIG_FILE. Check indentation and syntax."
        error "Run: yq '.' $CONFIG_FILE"
        exit 1
    fi
}

config_get() {
    local val
    val=$(yq -r "$1" "$CONFIG_FILE" 2>/dev/null) || true
    if [ "$val" = "null" ] || [ -z "$val" ]; then
        return 0
    fi
    echo "$val"
}

config_get_default() {
    local query="$1"
    local default="$2"
    local val
    val=$(config_get "$query")
    echo "${val:-$default}"
}

project_name() {
    config_get '.name'
}

# ── Input validation ────────────────────────────────────────────────

validate_name() {
    local name="$1"
    if [[ ! "$name" =~ ^[a-z0-9][a-z0-9._-]*$ ]]; then
        error "Invalid project name '$name'. Must match: ^[a-z0-9][a-z0-9._-]*$"
        exit 1
    fi
}

validate_feature() {
    local feature="$1"
    if [[ ! "$feature" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
        error "Invalid feature name '$feature'. Must match: ^[a-z0-9][a-z0-9-]*$"
        exit 1
    fi
}

validate_package() {
    local pkg="$1"
    if [[ ! "$pkg" =~ ^[a-z0-9][a-z0-9.+_-]*$ ]]; then
        error "Invalid package name '$pkg'. Must match: ^[a-z0-9][a-z0-9.+_-]*$"
        exit 1
    fi
}

validate_model() {
    local model="$1"
    if [[ ! "$model" =~ ^[a-zA-Z0-9][a-zA-Z0-9._:/-]*$ ]]; then
        error "Invalid model name '$model'. Must match: ^[a-zA-Z0-9][a-zA-Z0-9._:/-]*$"
        exit 1
    fi
}

# ── Commands ─────────────────────────────────────────────────────────

cmd_build_base() {
    log "Building base image..."
    docker build \
        -f "$SANDBOX_ROOT/base/Dockerfile" \
        -t sandbox-base:latest \
        "$SANDBOX_ROOT"
    log "Base image built: sandbox-base:latest"
}

cmd_build() {
    find_config
    local no_cache=""
    if [ "${1:-}" = "--no-cache" ]; then
        no_cache="--no-cache"
    fi
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi
    validate_name "$name"

    # Check base image exists
    if ! docker image inspect sandbox-base:latest &>/dev/null; then
        error "Base image not found. Run 'sandbox build-base' first."
        exit 1
    fi

    log "Building project image: sandbox-${name}:latest"

    # Generate Dockerfile from template
    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf $tmpdir" EXIT

    local dockerfile="$tmpdir/Dockerfile"
    local features_block=""
    local packages_block=""
    local setup_block=""

    # Features
    while IFS= read -r feature; do
        [ -z "$feature" ] && continue
        validate_feature "$feature"
        local script="$SANDBOX_ROOT/features/${feature}.sh"
        if [ ! -f "$script" ]; then
            error "Feature script not found: $script"
            exit 1
        fi
        cp "$script" "$tmpdir/${feature}.sh"
        features_block="${features_block}COPY ${feature}.sh /tmp/${feature}.sh
RUN chmod +x /tmp/${feature}.sh && /tmp/${feature}.sh && rm /tmp/${feature}.sh
"
    done < <(config_get '.features[]')

    # Packages
    local packages=""
    while IFS= read -r pkg; do
        [ -z "$pkg" ] && continue
        validate_package "$pkg"
        packages="${packages} ${pkg}"
    done < <(config_get '.packages[]')
    if [ -n "$packages" ]; then
        packages_block="RUN apt-get update && apt-get install -y --no-install-recommends${packages} && rm -rf /var/lib/apt/lists/*"
    fi

    # Custom setup script
    local setup_path
    setup_path=$(config_get '.setup')
    if [ -n "$setup_path" ]; then
        if [ ! -f "$setup_path" ]; then
            error "Setup script not found: $setup_path"
            exit 1
        fi
        cp "$setup_path" "$tmpdir/custom-setup.sh"
        setup_block="COPY custom-setup.sh /tmp/custom-setup.sh
RUN chmod +x /tmp/custom-setup.sh && /tmp/custom-setup.sh && rm /tmp/custom-setup.sh"
    fi

    # Generate Dockerfile by reading template and replacing placeholders
    # (Using line-by-line replacement to avoid awk/sed issues with & in strings)
    while IFS= read -r line; do
        case "$line" in
            *%%FEATURES%%*) printf '%s\n' "$features_block" ;;
            *%%PACKAGES%%*) printf '%s\n' "$packages_block" ;;
            *%%SETUP%%*)    printf '%s\n' "$setup_block" ;;
            *)              printf '%s\n' "$line" ;;
        esac
    done < "$SANDBOX_ROOT/templates/Dockerfile.project.tmpl" > "$dockerfile"

    # Build
    docker build $no_cache \
        -f "$dockerfile" \
        -t "sandbox-${name}:latest" \
        "$tmpdir"

    log "Project image built: sandbox-${name}:latest"
}

cmd_run() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi

    # Check image exists
    if ! docker image inspect "sandbox-${name}:latest" &>/dev/null; then
        error "Project image not found. Run 'sandbox build' first."
        exit 1
    fi

    # Parse --headless flag
    local mode
    mode=$(config_get_default '.claude.mode' 'interactive')
    local passthrough_args=()
    local parsing_passthrough=false

    while [ $# -gt 0 ]; do
        if [ "$1" = "--" ]; then
            parsing_passthrough=true
            shift
            continue
        fi
        if $parsing_passthrough; then
            passthrough_args+=("$1")
        elif [ "$1" = "--headless" ]; then
            mode="headless"
        fi
        shift
    done

    # Build common docker args
    _build_docker_args "$name"
    _read_claude_config

    # Run
    if [ "$mode" = "headless" ]; then
        if [ ${#passthrough_args[@]} -eq 0 ]; then
            error "Headless mode requires a prompt. Usage: sandbox run --headless -- \"your prompt here\""
            exit 1
        fi
        # Capture headless output to log file
        local log_dir="${HOME}/.sandbox/logs/${name}"
        mkdir -p "$log_dir"
        local log_file="${log_dir}/$(date +%Y%m%d-%H%M%S).log"
        log "Running sandbox-${name} in headless mode..."
        log "Output will be saved to: $log_file"

        local timeout_val
        timeout_val=$(config_get '.claude.timeout')
        if [ -n "$timeout_val" ] && [[ ! "$timeout_val" =~ ^[0-9]+[smh]?$ ]]; then
            error "Invalid timeout value '$timeout_val'. Use format like: 30s, 10m, 1h"
            exit 1
        fi
        local timeout_cmd=""
        if [ -n "$timeout_val" ]; then
            if command -v timeout &>/dev/null; then
                timeout_cmd="timeout $timeout_val"
            elif command -v gtimeout &>/dev/null; then
                timeout_cmd="gtimeout $timeout_val"
            else
                warn "Neither 'timeout' nor 'gtimeout' found. Timeout will not be enforced."
                warn "On macOS, install coreutils: brew install coreutils"
            fi
        fi

        $timeout_cmd docker run "${DOCKER_ARGS[@]}" \
            "sandbox-${name}:latest" \
            claude $SKIP_PERMISSIONS_FLAG ${CLAUDE_EXTRA_ARGS[@]+"${CLAUDE_EXTRA_ARGS[@]}"} -p "${passthrough_args[*]}" 2>&1 | tee "$log_file"
    elif [ ${#passthrough_args[@]} -gt 0 ]; then
        log "Running sandbox-${name} with command..."
        docker run "${DOCKER_ARGS[@]}" \
            "sandbox-${name}:latest" \
            "${passthrough_args[@]}"
    else
        log "Running sandbox-${name} interactively..."
        docker run -it "${DOCKER_ARGS[@]}" \
            "sandbox-${name}:latest"
    fi
}

# Shared Claude config reader — sets CLAUDE_EXTRA_ARGS array and SKIP_PERMISSIONS_FLAG string
_read_claude_config() {
    CLAUDE_EXTRA_ARGS=()
    while IFS= read -r arg; do
        [ -z "$arg" ] && continue
        case "$arg" in
            --dangerously-skip-permissions|--no-sandbox)
                warn "Blocked dangerous claude.args value: '$arg' — use claude.skip_permissions instead"
                continue
                ;;
        esac
        CLAUDE_EXTRA_ARGS+=("$arg")
    done < <(config_get '.claude.args[]')

    SKIP_PERMISSIONS_FLAG=""
    local skip_permissions
    skip_permissions=$(config_get_default '.claude.skip_permissions' 'false')
    if [ "$skip_permissions" = "true" ]; then
        SKIP_PERMISSIONS_FLAG="--dangerously-skip-permissions"
        local firewall
        firewall=$(config_get_default '.firewall' 'strict')
        if [ "$firewall" != "strict" ]; then
            warn "WARNING: skip_permissions is enabled without strict firewall!"
            warn "This is dangerous — Claude can access any network resource."
            warn "Set 'firewall: strict' in sandbox.yaml for safety."
        fi
    fi
}

# Shared docker args builder — sets global DOCKER_ARGS array
_build_docker_args() {
    local name="$1"
    DOCKER_ARGS=(
        "--name" "sandbox-${name}"
        "--rm"
        "--hostname" "sandbox"
        "--security-opt" "no-new-privileges"
        "--pids-limit" "256"
    )

    # Volumes
    DOCKER_ARGS+=("-v" "sandbox-${name}-claude:/home/node/.claude")
    DOCKER_ARGS+=("-v" "sandbox-${name}-home:/home/node/.persistent")
    DOCKER_ARGS+=("-v" "sandbox-${name}-cache:/home/node/.cache")

    # Ollama
    local has_ollama=false
    while IFS= read -r feature; do
        [ "$feature" = "ollama" ] && has_ollama=true
    done < <(config_get '.features[]')
    if $has_ollama; then
        DOCKER_ARGS+=("-v" "sandbox-ollama-models:/home/node/.ollama")
    fi

    # Mounts
    local has_mounts=false
    local mount_count
    mount_count=$(yq '.mounts | length' "$CONFIG_FILE" 2>/dev/null || echo "0")
    if [ "$mount_count" != "null" ] && [ "$mount_count" -gt 0 ] 2>/dev/null; then
        for i in $(seq 0 $((mount_count - 1))); do
            has_mounts=true
            local host_path container_path readonly_flag
            host_path=$(yq -r ".mounts[$i].host" "$CONFIG_FILE")
            container_path=$(yq -r ".mounts[$i].container" "$CONFIG_FILE")
            readonly_flag=$(yq -r ".mounts[$i].readonly // false" "$CONFIG_FILE")
            host_path="${host_path/#\~/$HOME}"
            if [[ "$host_path" == .* ]]; then
                host_path="$(cd "$(dirname "$CONFIG_FILE")" && pwd)/$(echo "$host_path" | sed 's|^\./||')"
            fi
            local mount_spec="${host_path}:${container_path}"
            if [ "$readonly_flag" = "true" ]; then
                mount_spec="${mount_spec}:ro"
            fi
            DOCKER_ARGS+=("-v" "$mount_spec")
        done
    fi
    if ! $has_mounts; then
        DOCKER_ARGS+=("-v" "$(pwd):/workspace")
    fi

    # Env vars
    local env_keys
    env_keys=$(yq -r '.env // {} | keys | .[]' "$CONFIG_FILE" 2>/dev/null) || true
    while IFS= read -r key; do
        [ -z "$key" ] && continue
        case "$key" in
            PATH|HOME|SHELL|USER|LD_PRELOAD|LD_LIBRARY_PATH|NODE_OPTIONS|\
            NPM_CONFIG_PREFIX|NPM_CONFIG_REGISTRY|PYTHONPATH|PROMPT_COMMAND|\
            EDITOR|VISUAL|DOCKER_HOST|\
            http_proxy|https_proxy|HTTP_PROXY|HTTPS_PROXY|ALL_PROXY|NO_PROXY|\
            SANDBOX_FIREWALL|SANDBOX_ALLOWED_DOMAINS|SANDBOX_GIT_*|ANTHROPIC_*)
                warn "Skipping dangerous env var '$key'"
                continue ;;
        esac
        local val
        val=$(yq -r ".env.${key}" "$CONFIG_FILE")
        DOCKER_ARGS+=("-e" "${key}=${val}")
    done <<< "$env_keys"

    # Git config
    local git_keys
    git_keys=$(yq -r '.git // {} | keys | .[]' "$CONFIG_FILE" 2>/dev/null) || true
    while IFS= read -r key; do
        [ -z "$key" ] && continue
        case "$key" in
            user.name|user.email|init.defaultBranch|core.autocrlf|core.eol|push.default|pull.rebase|commit.gpgsign|tag.gpgsign|merge.ff) ;;
            core.fsmonitor|core.sshCommand|core.hooksPath|core.pager)
                warn "Blocked dangerous git config key '$key'"
                continue
                ;;
            *)
                warn "Blocked unknown git config key '$key'"
                continue
                ;;
        esac
        local val
        val=$(yq -r ".git.\"${key}\"" "$CONFIG_FILE")
        local env_key
        env_key=$(echo "$key" | tr '[:lower:]' '[:upper:]' | sed 's/\./__/g')
        DOCKER_ARGS+=("-e" "SANDBOX_GIT_${env_key}=${val}")
    done <<< "$git_keys"

    # Firewall
    local firewall
    firewall=$(config_get_default '.firewall' 'strict')
    DOCKER_ARGS+=("-e" "SANDBOX_FIREWALL=${firewall}")
    if [ "$firewall" = "strict" ]; then
        DOCKER_ARGS+=("--cap-add" "NET_ADMIN" "--cap-add" "NET_RAW")

        # Pass allowed_domains as comma-separated env var
        local domains=""
        local domain_count
        domain_count=$(yq '.allowed_domains | length' "$CONFIG_FILE" 2>/dev/null || echo "0")
        if [ "$domain_count" != "null" ] && [ "$domain_count" -gt 0 ] 2>/dev/null; then
            for i in $(seq 0 $((domain_count - 1))); do
                local domain
                domain=$(yq -r ".allowed_domains[$i]" "$CONFIG_FILE")
                if [[ ! "$domain" =~ ^[a-zA-Z0-9]([a-zA-Z0-9.-]*[a-zA-Z0-9])?$ ]]; then
                    error "Invalid domain '$domain'. Must be a valid domain name."
                    exit 1
                fi
                domains="${domains:+${domains},}${domain}"
            done
        fi
        if [ -n "$domains" ]; then
            DOCKER_ARGS+=("-e" "SANDBOX_ALLOWED_DOMAINS=${domains}")
        fi
    fi

    # Resource limits
    local memory_limit
    memory_limit=$(config_get '.resources.memory')
    if [ -n "$memory_limit" ]; then
        DOCKER_ARGS+=("--memory" "$memory_limit")
    fi
    local cpu_limit
    cpu_limit=$(config_get '.resources.cpus')
    if [ -n "$cpu_limit" ]; then
        DOCKER_ARGS+=("--cpus" "$cpu_limit")
    fi
}

cmd_remote() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi

    if ! docker image inspect "sandbox-${name}:latest" &>/dev/null; then
        error "Project image not found. Run 'sandbox build' first."
        exit 1
    fi

    # Parse optional args
    local session_name="${name}"
    local spawn_mode="same-dir"
    while [ $# -gt 0 ]; do
        case "$1" in
            --name) session_name="$2"; shift 2 ;;
            --spawn) spawn_mode="$2"; shift 2 ;;
            *) break ;;
        esac
    done

    log "Starting Claude Code remote control for sandbox-${name}..."
    log "Connect via claude.ai/code or the Claude mobile app"
    echo ""

    _build_docker_args "$name"
    _read_claude_config

    docker run -it "${DOCKER_ARGS[@]}" \
        "sandbox-${name}:latest" \
        claude $SKIP_PERMISSIONS_FLAG ${CLAUDE_EXTRA_ARGS[@]+"${CLAUDE_EXTRA_ARGS[@]}"} remote-control --name "$session_name" --spawn "$spawn_mode" --verbose
}

cmd_claude() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi

    if ! docker image inspect "sandbox-${name}:latest" &>/dev/null; then
        error "Project image not found. Run 'sandbox build' first."
        exit 1
    fi

    # Check if container is already running — exec into it
    if [ "$(docker container inspect --format '{{.State.Running}}' "sandbox-${name}" 2>/dev/null)" = "true" ]; then
        log "Attaching to Claude Code in sandbox-${name}..."
        docker exec -it "sandbox-${name}" claude "$@"
        return
    fi

    # Otherwise start a new container with Claude Code
    log "Starting Claude Code in sandbox-${name}..."

    _build_docker_args "$name"
    _read_claude_config

    docker run -it "${DOCKER_ARGS[@]}" \
        "sandbox-${name}:latest" \
        claude $SKIP_PERMISSIONS_FLAG ${CLAUDE_EXTRA_ARGS[@]+"${CLAUDE_EXTRA_ARGS[@]}"} "$@"
}

cmd_claude_local() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi

    if ! docker image inspect "sandbox-${name}:latest" &>/dev/null; then
        error "Project image not found. Run 'sandbox build' first."
        exit 1
    fi

    # Require a model name
    if [ $# -eq 0 ]; then
        error "Usage: sandbox claude-local <model> [claude-args...]"
        error "Example: sandbox claude-local qwen3.5"
        error "See available models: sandbox models list"
        exit 1
    fi
    local model="$1"
    shift
    validate_model "$model"

    # Check ollama feature
    local has_ollama=false
    while IFS= read -r feature; do
        [ "$feature" = "ollama" ] && has_ollama=true
    done < <(config_get '.features[]')
    if ! $has_ollama; then
        error "The ollama feature is required for local models. Add 'ollama' to features in sandbox.yaml."
        exit 1
    fi

    # Check if container is already running — exec into it
    if [ "$(docker container inspect --format '{{.State.Running}}' "sandbox-${name}" 2>/dev/null)" = "true" ]; then
        log "Attaching to Claude Code (local: $model) in sandbox-${name}..."
        docker exec -it \
            -e ANTHROPIC_AUTH_TOKEN=ollama \
            -e ANTHROPIC_API_KEY="" \
            -e ANTHROPIC_BASE_URL=http://localhost:11434 \
            "sandbox-${name}" claude --model "$model" "$@"
        return
    fi

    log "Starting Claude Code with local model: $model"
    _build_docker_args "$name"
    _read_claude_config

    # Add Ollama API env vars
    DOCKER_ARGS+=("-e" "ANTHROPIC_AUTH_TOKEN=ollama")
    DOCKER_ARGS+=("-e" "ANTHROPIC_API_KEY=")
    DOCKER_ARGS+=("-e" "ANTHROPIC_BASE_URL=http://localhost:11434")

    docker run -it "${DOCKER_ARGS[@]}" \
        "sandbox-${name}:latest" \
        claude --model "$model" $SKIP_PERMISSIONS_FLAG ${CLAUDE_EXTRA_ARGS[@]+"${CLAUDE_EXTRA_ARGS[@]}"} "$@"
}

cmd_remote_local() {
    find_config
    local name
    name=$(project_name)
    if [ -z "$name" ]; then
        error "sandbox.yaml must have a 'name' field."
        exit 1
    fi

    if ! docker image inspect "sandbox-${name}:latest" &>/dev/null; then
