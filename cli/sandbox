            --spawn) spawn_mode="$2"; shift 2 ;;
            *) break ;;
        esac
    done

    log "Starting Claude Code remote control with local model: $model"
    log "Connect via claude.ai/code — LLM calls route to local Ollama model"
    echo ""

    _build_docker_args "$name"
    _read_claude_config

    # Add Ollama API env vars
    DOCKER_ARGS+=("-e" "ANTHROPIC_AUTH_TOKEN=ollama")
